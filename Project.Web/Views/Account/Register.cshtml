@model UserRegisterDto
@{
    ViewData["Title"] = "Kayıt Ol";
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
}

<section class="sqm-auth">
    <div class="sqm-auth-bg"></div>
    <div class="sqm-auth-grid"></div>

    <div class="sqm-auth-card">
        <div class="sqm-auth-icon">
            <i class="fa-solid fa-user-plus" aria-hidden="true"></i>
        </div>

        <h1 class="sqm-auth-title">Hesap Oluşturun</h1>
        <p class="sqm-auth-subtitle">Hemen kayıt olarak platformu kullanmaya başlayın.</p>

        <form asp-controller="Account" asp-action="Register" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="sqm-auth-summary"></div>

            <div class="sqm-field">
                <label asp-for="Email" class="sqm-label">E-posta Adresi</label>
                <div class="sqm-input-wrap">
                    <i class="fa-solid fa-envelope sqm-input-icon" aria-hidden="true"></i>
                    <input asp-for="Email" type="email" class="sqm-input" placeholder="ornek@eposta.com"
                           autocomplete="email" autofocus />
                </div>
                <span asp-validation-for="Email" class="sqm-field-validation"></span>
            </div>

            <div class="sqm-field">
                <label asp-for="UserName" class="sqm-label">Kullanıcı Adı</label>
                <div class="sqm-input-wrap">
                    <i class="fa-solid fa-user sqm-input-icon" aria-hidden="true"></i>
                    <input asp-for="UserName" class="sqm-input" placeholder="kullanici.adi" autocomplete="username" />
                </div>
                <span asp-validation-for="UserName" class="sqm-field-validation"></span>
            </div>

            <div class="sqm-field">
                <label asp-for="Password" class="sqm-label">Şifre</label>
                <div class="sqm-input-wrap">
                    <i class="fa-solid fa-key sqm-input-icon" aria-hidden="true"></i>
                    <input asp-for="Password" type="password" class="sqm-input" placeholder="••••••••"
                           autocomplete="new-password" id="sqmPassword" />
                    <button type="button" class="sqm-toggle-pass" id="sqmTogglePass" aria-label="Şifreyi göster">
                        <i class="fa-solid fa-eye" aria-hidden="true"></i>
                    </button>
                </div>
                <span asp-validation-for="Password" class="sqm-field-validation"></span>
            </div>

            <div class="sqm-field">
                <label asp-for="ConfirmPassword" class="sqm-label">Şifre Tekrar</label>
                <div class="sqm-input-wrap">
                    <i class="fa-solid fa-shield sqm-input-icon" aria-hidden="true"></i>
                    <input asp-for="ConfirmPassword" type="password" class="sqm-input" placeholder="••••••••"
                           autocomplete="new-password" id="sqmConfirmPassword" />
                    <button type="button" class="sqm-toggle-pass" id="sqmToggleConfirmPass" aria-label="Şifreyi göster">
                        <i class="fa-solid fa-eye" aria-hidden="true"></i>
                    </button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="sqm-field-validation"></span>
            </div>

            <button type="submit" class="sqm-auth-submit">
                <i class="fa-solid fa-user-check" aria-hidden="true"></i>
                Kayıt Ol
            </button>

            <div class="sqm-auth-divider">veya</div>

            <p class="sqm-auth-footer">
                Zaten hesabınız var mı?
                <a asp-controller="Account" asp-action="Login" class="sqm-link">Giriş yapın</a>
            </p>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            function setupPasswordToggle(toggleId, inputId) {
                const toggle = document.getElementById(toggleId);
                const input = document.getElementById(inputId);
                if (!toggle || !input) return;

                toggle.addEventListener('click', function () {
                    const isHidden = input.type === 'password';
                    input.type = isHidden ? 'text' : 'password';
                    toggle.querySelector('i').className = isHidden ? 'fa-solid fa-eye-slash' : 'fa-solid fa-eye';
                    toggle.setAttribute('aria-label', isHidden ? 'Şifreyi gizle' : 'Şifreyi göster');
                });
            }

            setupPasswordToggle('sqmTogglePass', 'sqmPassword');
            setupPasswordToggle('sqmToggleConfirmPass', 'sqmConfirmPassword');
        })();
    </script>
}