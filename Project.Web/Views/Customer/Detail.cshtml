@model Project.Web.Models.RestaurantDetailViewModel
@{
    ViewData["Title"] = Model.Name;
}

@section Styles {
    <style>
        .sqm-detail {
            position: relative;
            min-height: calc(100vh - 72px);
            padding: 2.5rem 0 4rem;
        }

        .sqm-detail-bg {
            position: fixed;
            inset: 0;
            background:
                radial-gradient(ellipse 70% 45% at 50% -10%, rgba(212, 165, 116, 0.15), transparent),
                linear-gradient(180deg, #121214 0%, #1a1816 100%);
            z-index: 0;
        }

        .sqm-detail-content {
            position: relative;
            z-index: 1;
        }

        .sqm-back {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            font-size: 0.88rem;
            font-weight: 500;
            color: var(--sqm-cream-muted);
            text-decoration: none;
            margin-bottom: 1.25rem;
            transition: color 0.2s ease;
        }

        .sqm-back:hover {
            color: var(--sqm-gold);
        }

        .sqm-detail-header {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 1.25rem;
            padding: 1.75rem;
            border-radius: 1.25rem;
            background: linear-gradient(145deg, #252528, #1c1c1f);
            border: 1px solid var(--sqm-border);
            box-shadow: var(--sqm-shadow);
            margin-bottom: 2rem;
        }

        .sqm-detail-avatar {
            flex-shrink: 0;
            width: 4rem;
            height: 4rem;
            border-radius: 1rem;
            background: linear-gradient(135deg, var(--sqm-gold), #b8895a);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: var(--sqm-bg);
            font-size: 1.7rem;
            font-weight: 800;
            box-shadow: 0 8px 20px rgba(212, 165, 116, 0.28);
        }

        .sqm-detail-title {
            font-size: clamp(1.5rem, 4vw, 2.1rem);
            font-weight: 800;
            letter-spacing: -0.02em;
            color: var(--sqm-cream);
            margin: 0;
        }

        .sqm-detail-title-row {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 0.85rem;
        }

        .sqm-detail-rating {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            padding: 0.4rem 0.85rem;
            border-radius: 2rem;
            font-size: 0.95rem;
            font-weight: 700;
            letter-spacing: 0.01em;
            border: 1px solid transparent;
            white-space: nowrap;
        }

        .sqm-detail-rating i {
            font-size: 0.9rem;
        }

        .sqm-detail-rating .sqm-rating-count {
            font-weight: 500;
            opacity: 0.85;
            font-size: 0.82rem;
        }

        .sqm-rating-gold {
            color: #FFD700;
            border-color: rgba(255, 215, 0, 0.35);
            background: rgba(255, 215, 0, 0.1);
        }

        .sqm-rating-teal {
            color: #0dcaf0;
            border-color: rgba(13, 202, 240, 0.35);
            background: rgba(13, 202, 240, 0.1);
        }

        .sqm-rating-softred {
            color: #e05252;
            border-color: rgba(224, 82, 82, 0.35);
            background: rgba(224, 82, 82, 0.1);
        }

        .sqm-rating-muted {
            color: #6c757d;
            border-color: rgba(108, 117, 125, 0.35);
            background: rgba(108, 117, 125, 0.1);
        }

        .sqm-btn-reviews {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            padding: 0.45rem 0.95rem;
            border-radius: 0.75rem;
            border: 1px solid rgba(212, 165, 116, 0.35);
            background: rgba(212, 165, 116, 0.08);
            color: var(--sqm-gold);
            font-weight: 600;
            font-size: 0.85rem;
            text-decoration: none;
            white-space: nowrap;
            transition: border-color 0.2s ease, background 0.2s ease, color 0.2s ease, transform 0.2s ease;
        }

        .sqm-btn-reviews:hover {
            border-color: rgba(212, 165, 116, 0.6);
            background: rgba(212, 165, 116, 0.16);
            color: var(--sqm-gold);
            transform: translateY(-1px);
        }

        .sqm-btn-reviews i {
            font-size: 0.8rem;
        }

        .sqm-fav-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 2.5rem;
            height: 2.5rem;
            border-radius: 999px;
            border: 1px solid var(--sqm-border);
            background: rgba(18, 18, 20, 0.55);
            color: var(--sqm-cream-muted);
            cursor: pointer;
            transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
            flex-shrink: 0;
        }

        .sqm-fav-btn:hover {
            color: #e05252;
            border-color: rgba(224, 82, 82, 0.4);
            background: rgba(224, 82, 82, 0.1);
            transform: scale(1.05);
        }

        .sqm-fav-btn.is-active {
            color: #e05252;
            border-color: rgba(224, 82, 82, 0.45);
            background: rgba(224, 82, 82, 0.12);
        }

        .sqm-fav-btn:disabled {
            opacity: 0.6;
            cursor: wait;
        }

        .sqm-detail-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 1.25rem;
            margin-top: 0.5rem;
            color: var(--sqm-cream-muted);
            font-size: 0.85rem;
        }

        .sqm-detail-meta span {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
        }

        .sqm-detail-meta i {
            color: var(--sqm-gold);
        }

        .sqm-panel {
            padding: 1.5rem;
            border-radius: 1.25rem;
            background: linear-gradient(145deg, #252528, #1c1c1f);
            border: 1px solid var(--sqm-border);
            height: 100%;
            overflow: visible
        }

        .sqm-panel-title {
            font-size: 1.05rem;
            font-weight: 700;
            color: var(--sqm-cream);
            margin-bottom: 1.25rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .sqm-panel-title i {
            color: var(--sqm-gold);
        }

        .sqm-tabs {
            border: none;
            gap: 0.5rem;
            margin-bottom: 1.5rem;
            flex-wrap: wrap;
        }

        .sqm-tabs .nav-link {
            border: 1px solid var(--sqm-border);
            border-radius: 2rem;
            padding: 0.45rem 1.05rem;
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--sqm-cream-muted);
            background: transparent;
            transition: all 0.2s ease;
        }

        .sqm-tabs .nav-link:hover {
            color: var(--sqm-cream);
            border-color: rgba(212, 165, 116, 0.4);
        }

        .sqm-tabs .nav-link.active {
            color: var(--sqm-bg);
            background: linear-gradient(135deg, var(--sqm-gold), #b8895a);
            border-color: transparent;
        }

        .sqm-tabs .nav-link .count {
            opacity: 0.7;
            font-weight: 500;
            margin-left: 0.25rem;
        }

        .sqm-menu-item {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 1rem;
            padding: 1rem 0;
            border-bottom: 1px solid var(--sqm-border);
        }

        .sqm-menu-item:last-child {
            border-bottom: none;
        }

        .sqm-menu-item h4 {
            font-size: 0.98rem;
            font-weight: 600;
            color: var(--sqm-cream);
            margin: 0 0 0.3rem;
        }

        .sqm-menu-item p {
            font-size: 0.85rem;
            color: var(--sqm-cream-muted);
            margin: 0;
            line-height: 1.5;
        }

        .sqm-menu-price {
            flex-shrink: 0;
            font-size: 0.95rem;
            font-weight: 700;
            color: var(--sqm-gold);
            white-space: nowrap;
        }

        .sqm-muted {
            color: var(--sqm-cream-muted);
            font-size: 0.9rem;
            padding: 1rem 0;
            margin: 0;
        }

        .sqm-tables-legend {
            display: flex;
            gap: 1.25rem;
            margin-bottom: 1.25rem;
            font-size: 0.8rem;
            color: var(--sqm-cream-muted);
        }

        .sqm-tables-legend span {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
        }

        .sqm-legend-dot {
            width: 0.75rem;
            height: 0.75rem;
            border-radius: 0.25rem;
        }

        .sqm-legend-dot.free {
            background: #34d399;
        }

        .sqm-legend-dot.busy {
            background: #e57373;
        }

        .sqm-tables-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(72px, 1fr));
            gap: 0.75rem;
        }

        .sqm-table {
            aspect-ratio: 1 / 1;
            border-radius: 0.85rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 0.2rem;
            border: 1px solid var(--sqm-border);
            text-align: center;
            transition: transform 0.2s ease;
            position: relative;
        }

        .sqm-qr-popover {
            position: absolute;
            bottom: calc(100% + 0.6rem);
            left: 50%;
            transform: translateX(-50%) translateY(6px);
            background: linear-gradient(145deg, #2a2a2d, #1c1c1f);
            border: 1px solid var(--sqm-border);
            border-radius: 0.85rem;
            padding: 0.6rem;
            box-shadow: var(--sqm-shadow);
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.15s ease, transform 0.15s ease;
            z-index: 10;
            white-space: nowrap;
        }

        .sqm-qr-popover::after {
            content: "";
            position: absolute;
            top: 100%;
            left: 50%;
            transform: translateX(-50%);
            border: 6px solid transparent;
            border-top-color: #1c1c1f;
        }

        .sqm-qr-popover img {
            display: block;
            width: 120px;
            height: 120px;
            border-radius: 0.5rem;
            background: #fff;
            padding: 6px;
        }

        .sqm-qr-popover .qr-label {
            text-align: center;
            font-size: 0.72rem;
            font-weight: 600;
            color: var(--sqm-cream-muted);
            margin-top: 0.4rem;
        }

        .sqm-table.qr-visible .sqm-qr-popover {
            opacity: 1;
            pointer-events: auto;
            transform: translateX(-50%) translateY(0);
        }

        .sqm-table:hover {
            transform: translateY(-2px);
        }

        .sqm-table i {
            font-size: 1.1rem;
        }

        .sqm-table .num {
            font-size: 0.8rem;
            font-weight: 700;
        }

        .sqm-table .state {
            font-size: 0.65rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.03em;
        }

        .sqm-table.free {
            background: rgba(52, 211, 153, 0.1);
            border-color: rgba(52, 211, 153, 0.3);
            color: #34d399;
        }

        .sqm-table.busy {
            background: rgba(229, 115, 115, 0.1);
            border-color: rgba(229, 115, 115, 0.3);
            color: #e57373;
        }

        .sqm-table .num,
        .sqm-table.free .num {
            color: var(--sqm-cream);
        }

        .sqm-tables-summary {
            display: flex;
            gap: 0.75rem;
            margin-top: 1.25rem;
        }

        .sqm-table {
            cursor: pointer;
            user-select: none;
        }

        .sqm-table.busy {
            cursor: not-allowed;
        }

        .sqm-table.selected {
            outline: 3px solid var(--sqm-gold);
            outline-offset: 2px;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(212, 165, 116, 0.35);
        }

        .sqm-select-table-btn {
            width: 100%;
            margin-top: 1.25rem;
            padding: 0.75rem 1rem;
            border-radius: 0.85rem;
            border: none;
            font-weight: 700;
            font-size: 0.9rem;
            color: var(--sqm-bg);
            background: linear-gradient(135deg, var(--sqm-gold), #b8895a);
            transition: opacity 0.2s ease, transform 0.2s ease;
        }

        .sqm-select-table-btn:disabled {
            opacity: 0.4;
            cursor: not-allowed;
        }

        .sqm-select-table-btn:not(:disabled):hover {
            transform: translateY(-1px);
        }

        .sqm-summary-chip {
            flex: 1;
            text-align: center;
            padding: 0.75rem 0.5rem;
            border-radius: 0.75rem;
            border: 1px solid var(--sqm-border);
            background: rgba(18, 18, 20, 0.5);
        }

        .sqm-summary-chip strong {
            display: block;
            font-size: 1.25rem;
            font-weight: 800;
        }

        .sqm-summary-chip span {
            font-size: 0.72rem;
            color: var(--sqm-cream-muted);
        }

        .sqm-summary-chip.free strong {
            color: #34d399;
        }

        .sqm-summary-chip.busy strong {
            color: #e57373;
        }

        .sqm-btn-primary {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.6rem 1.2rem;
            border-radius: 0.75rem;
            border: 1px solid transparent;
            font-weight: 600;
            font-size: 0.9rem;
            color: var(--sqm-bg) !important;
            /* Arka plan koyu olduğu için yazı rengini korur */
            background: linear-gradient(135deg, var(--sqm-gold), #b8895a);
            text-decoration: none;
            transition: all 0.2s ease;
            box-shadow: 0 4px 12px rgba(212, 165, 116, 0.15);
        }

        .sqm-btn-primary:hover {
            color: var(--sqm-bg) !important;
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(212, 165, 116, 0.25);
            opacity: 0.9;
        }
    </style>
}

<section class="sqm-detail">
    <div class="sqm-detail-bg"></div>

    <div class="container sqm-detail-content">
        <a class="sqm-back" asp-controller="Customer" asp-action="Index">
            <i class="fa-solid fa-arrow-left" aria-hidden="true"></i> Restoranlara dön
        </a>

        @{
            var detailRatingClass = Model.AverageRating >= 4.0 ? "sqm-rating-gold"
                : Model.AverageRating >= 3.0 ? "sqm-rating-teal"
                : Model.AverageRating > 0 ? "sqm-rating-softred"
                : "sqm-rating-muted";
        }

        <div class="sqm-detail-header">
            <!-- mevcut avatar + başlık -->
            <div class="flex-grow-1">
                <h1 class="sqm-detail-title">@Model.Name</h1>
                <!-- meta bilgiler -->
            </div>
            @if (Model.CanManageRestaurant)
            {
                <a class="sqm-btn-primary" asp-controller="Owner" asp-action="Manage" asp-route-id="@Model.Id">
                    <i class="fa-solid fa-pen-to-square" aria-hidden="true"></i>
                    Restoranı Düzenle / Yönet
                </a>
            }
        </div>

        <div class="sqm-detail-header">
            <span class="sqm-detail-avatar">
                @(string.IsNullOrWhiteSpace(Model.Name) ? "?" : Model.Name.Trim().Substring(0, 1).ToUpper())
            </span>
            <div>
                <div class="sqm-detail-title-row">
                    <h1 class="sqm-detail-title">@Model.Name</h1>
                    <span class="sqm-detail-rating @detailRatingClass">
                        <i class="fa-solid fa-star" aria-hidden="true"></i>
                        @if (Model.AverageRating <= 0 || Model.ReviewCount == 0)
                        {
                            <span>Henüz puanlanmadı</span>
                        }
                        else
                        {
                            <span>@Model.AverageRating.ToString("0.0")</span>
                            <span class="sqm-rating-count">(@Model.ReviewCount Değerlendirme)</span>
                        }
                    </span>
                    <a class="sqm-btn-reviews" asp-controller="Customer" asp-action="Reviews" asp-route-id="@Model.Id">
                        <i class="fa-solid fa-star" aria-hidden="true"></i>
                        İncelemeler
                    </a>
                    <button type="button"
                            class="sqm-fav-btn @(Model.IsFavorite ? "is-active" : "")"
                            data-restaurant-id="@Model.Id"
                            data-favorite="@(Model.IsFavorite ? "true" : "false")"
                            aria-label="@(Model.IsFavorite ? "Favorilerden çıkar" : "Favorilere ekle")"
                            onclick="window.sqmToggleFavorite(this);">
                        <i class="@(Model.IsFavorite ? "fa-solid text-danger" : "fa-regular") fa-heart" aria-hidden="true"></i>
                    </button>
                </div>
                <div class="sqm-detail-meta">
                    <span><i class="fa-solid fa-layer-group" aria-hidden="true"></i> @Model.CategoryCount
                        Kategori</span>
                        <span><i class="fa-solid fa-utensils" aria-hidden="true"></i> @Model.MenuItemCount Ürün</span>
                        <span><i class="fa-solid fa-chair" aria-hidden="true"></i> @Model.TableCount Masa</span>
                        <span><i class="fa-solid fa-circle-check" aria-hidden="true"></i> @Model.AvailableTableCount Boş /
                            @Model.OccupiedTableCount Dolu</span>
                        </div>
                    </div>
                </div>

                <div class="row g-4">
                    <div class="col-12 col-lg-8">
                        <div class="sqm-panel">
                            <h2 class="sqm-panel-title"><i class="fa-solid fa-book-open" aria-hidden="true"></i> Menü</h2>

                            @if (!Model.Categories.Any())
                            {
                                <p class="sqm-muted">Bu restoran için henüz menü kategorisi eklenmemiş.</p>
                            }
                            else
                            {
                                <ul class="nav sqm-tabs" role="tablist">
                                    @for (var i = 0; i < Model.Categories.Count; i++)
                                    {
                                        var category = Model.Categories[i];
                                        <li class="nav-item" role="presentation">
                                            <button class="nav-link @(i == 0 ? "active" : "")" id="tab-btn-@category.Id"
                                                    data-bs-toggle="tab" data-bs-target="#tab-pane-@category.Id" type="button" role="tab"
                                                    aria-controls="tab-pane-@category.Id" aria-selected="@(i == 0 ? "true" : "false")">
                                                @category.Name <span class="count">(@category.Items.Count)</span>
                                            </button>
                                        </li>
                                    }
                                </ul>

                                <div class="tab-content">
                                    @for (var i = 0; i < Model.Categories.Count; i++)
                                    {
                                        var category = Model.Categories[i];
                                        <div class="tab-pane fade @(i == 0 ? "show active" : "")" id="tab-pane-@category.Id"
                                             role="tabpanel" aria-labelledby="tab-btn-@category.Id" tabindex="0">
                                            @if (!category.Items.Any())
                                            {
                                                <p class="sqm-muted">Bu kategoride henüz ürün bulunmuyor.</p>
                                            }
                                            else
                                            {
                                                foreach (var item in category.Items)
                                                {
                                                    <div class="sqm-menu-item">
                                                        <div>
                                                            <h4>@item.Name</h4>
                                                            @if (!string.IsNullOrWhiteSpace(item.Description))
                                                            {
                                                                <p>@item.Description</p>
                                                            }
                                                        </div>
                                                        <div class="sqm-menu-price">@item.Price.ToString("N2") ₺</div>
                                                    </div>
                                                }
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>

                    <div class="col-12 col-lg-4">
                        <div class="sqm-panel">
                            <h2 class="sqm-panel-title"><i class="fa-solid fa-chair" aria-hidden="true"></i> Masa Durumu</h2>

                            @if (!Model.Tables.Any())
                            {
                                <p class="sqm-muted">Bu restoran için tanımlı masa bulunmuyor.</p>
                            }
                            else
                            {
                                <div class="sqm-tables-legend">
                                    <span><span class="sqm-legend-dot free" aria-hidden="true"></span> Boş</span>
                                    <span><span class="sqm-legend-dot busy" aria-hidden="true"></span> Dolu</span>
                                </div>

                                <div class="sqm-tables-grid" id="sqmTablesGrid">
                                    @foreach (var table in Model.Tables)
                                    {
                                        <div class="sqm-table @(table.IsOccupied ? "busy" : "free")" data-table-id="@table.Id"
                                             data-table-number="@table.TableNumber"
                                             data-occupied="@table.IsOccupied.ToString().ToLower()"
                                             title="Masa @table.TableNumber - @(table.IsOccupied ? "Dolu" : "Boş")">
                                            <i class="fa-solid @(table.IsOccupied ? "fa-users" : "fa-check")" aria-hidden="true"></i>
                                            <span class="num">@table.TableNumber</span>
                                            <span class="state">@(table.IsOccupied ? "Dolu" : "Boş")</span>

                                            <div class="sqm-qr-popover">
                                                <img src="@Url.Action("QrCode", "Table", new { tableId = table.Id })"
                                                     alt="Masa @table.TableNumber QR kodu" loading="lazy" />
                                                <div class="qr-label">Masa @table.TableNumber</div>
                                            </div>
                                        </div>
                                    }
                                </div>
                                @*test*@

                                <div class="sqm-tables-summary">
                                    <div class="sqm-summary-chip free">
                                        <strong>@Model.AvailableTableCount</strong>
                                        <span>Boş Masa</span>
                                    </div>
                                    <div class="sqm-summary-chip busy">
                                        <strong>@Model.OccupiedTableCount</strong>
                                        <span>Dolu Masa</span>
                                    </div>
                                </div>

                                <button type="button" class="sqm-select-table-btn" id="sqmSelectTableBtn" disabled>
                                    Masayı Seç
                                </button>
                                @if (Model.CanManageRestaurant)
                                {
                                    <div class="col-12 my-5">
                                        @await Html.PartialAsync("~/Views/Owner/_Orders.cshtml", Model.OwnerOrders)
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        </section>
        @section Scripts {
            <script>
                (function () {
                    const grid = document.getElementById('sqmTablesGrid');
                    const selectBtn = document.getElementById('sqmSelectTableBtn');
                    if (!grid || !selectBtn) return;

                    let selectedTableId = null;
                    let selectedTableNumber = null;

                    grid.addEventListener('click', function (e) {
                        const cell = e.target.closest('.sqm-table');
                        if (!cell || cell.dataset.occupied === 'true') return;

                        const alreadySelected = cell.classList.contains('selected');

                        grid.querySelectorAll('.sqm-table.selected')
                            .forEach(el => el.classList.remove('selected'));

                        if (alreadySelected) {
                            selectedTableId = null;
                            selectedTableNumber = null;
                        } else {
                            cell.classList.add('selected');
                            selectedTableId = cell.dataset.tableId;
                            selectedTableNumber = cell.dataset.tableNumber;
                        }

                        selectBtn.disabled = !selectedTableId;
                        selectBtn.textContent = selectedTableId
                            ? `Masa ${selectedTableNumber} - Seç`
                            : 'Masayı Seç';
                    });

                    selectBtn.addEventListener('click', function () {
                        if (!selectedTableId) return;
                        window.location.href = '@Url.Action("Menu", "Customer")' + '?tableId=' + selectedTableId;
                    });

                    // Masa üzerine gelince (desktop) / basılı tutunca (mobil) QR göster
                    let longPressTimer = null;
                    const LONG_PRESS_MS = 400;

                    grid.querySelectorAll('.sqm-table').forEach(cell => {
                        cell.addEventListener('mouseenter', () => cell.classList.add('qr-visible'));
                        cell.addEventListener('mouseleave', () => cell.classList.remove('qr-visible'));

                        cell.addEventListener('touchstart', () => {
                            longPressTimer = setTimeout(() => {
                                grid.querySelectorAll('.sqm-table.qr-visible')
                                    .forEach(el => el.classList.remove('qr-visible'));
                                cell.classList.add('qr-visible');
                            }, LONG_PRESS_MS);
                        }, { passive: true });

                        cell.addEventListener('touchend', () => {
                            clearTimeout(longPressTimer);
                            cell.classList.remove('qr-visible');
                        });

                        cell.addEventListener('touchmove', () => {
                            clearTimeout(longPressTimer);
                        });
                    });
                })();
            </script>
            <partial name="_FavoriteToggleScript" />
        }