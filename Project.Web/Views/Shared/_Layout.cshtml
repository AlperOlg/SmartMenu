<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Smart QR Menu — Yapay zeka destekli dijital menü deneyimi." />
    <title>@ViewData["Title"] - Smart QR Menu</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" />
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />

    <style>
        :root {
            --sqm-bg: #121214;
            --sqm-surface: #1c1c1f;
            --sqm-surface-elevated: #252528;
            --sqm-cream: #f5f0e8;
            --sqm-cream-muted: #c8c0b4;
            --sqm-gold: #d4a574;
            --sqm-gold-soft: rgba(212, 165, 116, 0.15);
            --sqm-border: rgba(245, 240, 232, 0.08);
            --sqm-shadow: 0 8px 32px rgba(0, 0, 0, 0.35);
        }

        *,
        *::before,
        *::after {
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            background-color: var(--sqm-bg);
            color: var(--sqm-cream);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            overflow-x: hidden;
        }

        .sqm-navbar {
            background: rgba(18, 18, 20, 0.9) !important;
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--sqm-border);
            padding-block: 0.75rem;
        }

        .sqm-brand {
            font-weight: 700;
            font-size: 1.05rem;
            color: var(--sqm-cream) !important;
            letter-spacing: -0.02em;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            text-decoration: none;
            flex-shrink: 0;
        }

        .sqm-brand-icon {
            width: 2rem;
            height: 2rem;
            border-radius: 0.5rem;
            background: linear-gradient(135deg, var(--sqm-gold), #b8895a);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: var(--sqm-bg);
            font-size: 0.9rem;
        }

        .sqm-nav-link {
            color: var(--sqm-cream-muted) !important;
            font-weight: 500;
            font-size: 0.9rem;
            padding: 0.6rem 0.85rem !important;
            border-radius: 0.5rem;
            transition: color 0.2s ease, background 0.2s ease;
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }

        .sqm-nav-link:hover,
        .sqm-nav-link:focus {
            color: var(--sqm-cream) !important;
            background: var(--sqm-gold-soft);
        }

        .sqm-nav-cta {
            background: linear-gradient(135deg, var(--sqm-gold), #b8895a);
            color: var(--sqm-bg) !important;
            font-weight: 600;
            border-radius: 0.5rem;
            padding: 0.5rem 1rem !important;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.4rem;
        }

        .sqm-nav-cta:hover {
            opacity: 0.92;
            color: var(--sqm-bg) !important;
        }

        .navbar-toggler {
            border-color: var(--sqm-border);
            padding: 0.4rem 0.55rem;
            background: rgba(245, 240, 232, 0.03);
        }

        .navbar-toggler:focus {
            box-shadow: 0 0 0 0.2rem var(--sqm-gold-soft);
        }

        .navbar-toggler-icon {
            filter: invert(1) opacity(0.85);
            width: 1.25rem;
            height: 1.25rem;
        }

        .sqm-main {
            flex: 1;
            width: 100%;
        }

        .sqm-footer {
            background: var(--sqm-surface);
            border-top: 1px solid var(--sqm-border);
            padding: 1.5rem 0;
            margin-top: auto;
        }

        .sqm-footer-text {
            color: var(--sqm-cream-muted);
            font-size: 0.85rem;
            margin: 0;
        }

        .sqm-footer-link {
            color: var(--sqm-gold);
            text-decoration: none;
        }

        .sqm-footer-link:hover {
            color: var(--sqm-cream);
        }

        .sqm-footer-social a {
            color: var(--sqm-cream-muted);
            font-size: 1.1rem;
            transition: color 0.2s ease;
        }

        .sqm-footer-social a:hover {
            color: var(--sqm-gold);
        }

        .sqm-user-chip {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 0.85rem;
            border-radius: 0.5rem;
            background: var(--sqm-gold-soft);
            border: 1px solid rgba(212, 165, 116, 0.25);
            color: var(--sqm-cream) !important;
            font-weight: 600;
            font-size: 0.9rem;
        }

        .sqm-user-chip i {
            color: var(--sqm-gold);
        }

        .sqm-logout-form {
            margin: 0;
            width: 100%;
        }

        .sqm-logout-btn {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            background: transparent;
            border: 1px solid var(--sqm-border);
            color: var(--sqm-cream-muted);
            font-weight: 500;
            font-size: 0.9rem;
            padding: 0.5rem 0.9rem;
            border-radius: 0.5rem;
            cursor: pointer;
            transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
        }

        .sqm-logout-btn:hover {
            color: var(--sqm-cream);
            border-color: rgba(212, 165, 116, 0.5);
            background: var(--sqm-gold-soft);
        }
.sqm-role-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.15rem 0.5rem;
    border-radius: 1rem;
    background: rgba(212, 165, 116, 0.25);
    color: var(--sqm-gold);
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
}

.sqm-role-badge-sm {
    padding: 0.1rem 0.35rem;
    font-size: 0.6rem;
}
        @@media (max-width: 991.98px) {
            .navbar-collapse {
                background: var(--sqm-surface);
                margin-inline: -1rem;
                padding: 1rem;
                border-radius: 0.75rem;
                margin-top: 0.75rem;
                border: 1px solid var(--sqm-border);
                box-shadow: var(--sqm-shadow);
            }
            .navbar-nav {
                gap: 0.5rem;
            }
            .sqm-logout-form {
                margin-top: 0.25rem;
            }
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg sqm-navbar sticky-top">
            <div class="container">
                <a class="sqm-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="sqm-brand-icon"><i class="fa-solid fa-qrcode"></i></span>
                    Smart QR Menu
                </a>

                @if (User.Identity is not null && User.Identity.IsAuthenticated)
                {
                    string quickController = User.IsInRole("Admin") ? "Admin" : "Customer";
    
    <div class="d-flex align-items-center gap-2 d-lg-none ms-auto me-2" style="max-width: 60%; overflow: hidden;">
        <a class="btn sqm-nav-cta btn-sm py-1 px-2 text-truncate" style="font-size: 0.75rem; min-height: 28px;" asp-area="" asp-controller="@quickController" asp-action="Index">
            <i class="fa-solid fa-utensils"></i> Panel
        </a>
        <span class="text-truncate d-flex align-items-center gap-1" style="font-size: 0.75rem; color: var(--sqm-cream-muted); max-width: 100px;">
            <i class="fa-solid fa-user text-warning"></i>@User.Identity.Name
            <span class="sqm-role-badge sqm-role-badge-sm">
                @(User.IsInRole("Admin") ? "Yönetici" : User.IsInRole("Owner") ? "Sahibi" : "Müşteri")
            </span>
        </span>
    </div>
                }

                <button class="navbar-toggler @(User.Identity is not null && User.Identity.IsAuthenticated ? "" : "ms-auto")" type="button" data-bs-toggle="collapse"
                        data-bs-target="#sqmNavbar" aria-controls="sqmNavbar"
                        aria-expanded="false" aria-label="Menüyü aç">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="sqmNavbar">
                    <ul class="navbar-nav mx-auto align-items-lg-center d-none d-lg-flex">
                        @if (User.Identity is not null && User.Identity.IsAuthenticated)
                        {
                            string centerController = User.IsInRole("Admin") ? "Admin" : "Customer";
                            <li class="nav-item">
                                <a class="nav-link sqm-nav-link px-3 py-2 fw-bold" style="color: var(--sqm-gold) !important; background: var(--sqm-gold-soft);" 
                                   asp-area="" asp-controller="@centerController" asp-action="Index">
                                    <i class="fa-solid fa-utensils me-1"></i> Restoranlar Paneli
                                </a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-1">
                        <li class="nav-item">
                            <a class="nav-link sqm-nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="fa-solid fa-house"></i> Ana Sayfa
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link sqm-nav-link" href="#ozellikler">
                                <i class="fa-solid fa-paper-plane"></i> Özellikler
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link sqm-nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">
                                <i class="fa-solid fa-shield-halved"></i> Gizlilik
                            </a>
                        </li>
                        
                        @if (User.Identity is not null && User.Identity.IsAuthenticated)
                        {
                            string centerController = User.IsInRole("Admin") ? "Admin" : "Customer";
                            <li class="nav-item d-lg-none">
                                <a class="nav-link sqm-nav-link" asp-area="" asp-controller="@centerController" asp-action="Index">
                                    <i class="fa-solid fa-utensils"></i> Restoranlar Paneli
                                </a>
                            </li>

                            <li class="nav-item ms-lg-2 mt-2 mt-lg-0 d-none d-lg-inline-flex align-items-center gap-2">
    <span class="sqm-user-chip">
        <i class="fa-solid fa-circle-user"></i>
        Merhaba, @User.Identity.Name
        <span class="sqm-role-badge">
            @(User.IsInRole("Admin") ? "Yönetici" : User.IsInRole("Owner") ? "Restoran Sahibi" : "Müşteri")
        </span>
    </span>

    @if (!User.IsInRole("Owner") && !User.IsInRole("Admin"))
    {
        <a class="btn sqm-nav-cta btn-sm" asp-area="" asp-controller="Owner" asp-action="CreateRestaurant">
            <i class="fa-solid fa-store"></i> Restoran Oluştur
        </a>
    }
    else if (User.IsInRole("Owner"))
    {
        <a class="btn sqm-nav-cta btn-sm" asp-area="" asp-controller="Owner" asp-action="Dashboard">
            <i class="fa-solid fa-gauge"></i> Panelim
        </a>
    }
</li>  
                            <li class="nav-item ms-lg-2 mt-1 mt-lg-0">
                                <form class="sqm-logout-form" asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                                    <button type="submit" class="sqm-logout-btn w-100 justify-content-center">
                                        <i class="fa-solid fa-right-from-bracket"></i> Çıkış Yap
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item mt-1 mt-lg-0">
                                <a class="nav-link sqm-nav-link" asp-area="" asp-controller="Account" asp-action="Login">
                                    <i class="fa-solid fa-right-to-bracket"></i> Giriş Yap
                                </a>
                            </li>
                            <li class="nav-item ms-lg-2 mt-1 mt-lg-0">
                                <a class="nav-link sqm-nav-link sqm-nav-cta" asp-area="" asp-controller="Account" asp-action="Register">
                                    <i class="fa-solid fa-arrow-right"></i> Başlayalım
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="sqm-main" role="main">
        @RenderBody()
    </main>

    <footer class="sqm-footer">
        <div class="container">
            <div class="row align-items-center gy-3">
                <div class="col-12 col-md-6 text-center text-md-start">
                    <p class="sqm-footer-text">
                        &copy; @DateTime.Now.Year Smart QR Menu — Gastronomi için akıllı dijital menü.
                    </p>
                </div>
                <div class="col-12 col-md-6">
                    <div class="d-flex justify-content-center justify-content-md-end align-items-center gap-3 sqm-footer-social">
                        <a href="#" aria-label="Instagram"><i class="fa-brands fa-instagram"></i></a>
                        <a href="#" aria-label="Twitter"><i class="fa-brands fa-x-twitter"></i></a>
                        <a asp-area="" asp-controller="Home" asp-action="Privacy" class="sqm-footer-link">Gizlilik Politikası</a>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
            crossorigin="anonymous"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>