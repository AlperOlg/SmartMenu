@{
    ViewData["Title"] = "AI Asistan";
}

<style>
    .ai-page {
        padding: 2rem 0 3rem;
        background:
            radial-gradient(ellipse 70% 50% at 10% 0%, var(--sqm-gold-soft, rgba(212, 165, 116, 0.14)), transparent 55%),
            radial-gradient(ellipse 50% 40% at 90% 20%, rgba(212, 165, 116, 0.08), transparent 50%);
    }

    .ai-intro-card,
    .ai-chat-card {
        background: rgba(28, 28, 31, 0.95);
        border: 1px solid var(--sqm-border, rgba(245, 240, 232, 0.08));
        border-radius: 1rem;
        box-shadow: var(--sqm-shadow, 0 12px 40px rgba(0, 0, 0, 0.5));
        height: 100%;
    }

    .ai-intro-card {
        padding: 1.75rem;
    }

    .ai-intro-icon {
        width: 3.25rem;
        height: 3.25rem;
        border-radius: 0.9rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, var(--sqm-gold, #d4a574), #b8895a);
        color: var(--sqm-bg, #121214);
        font-size: 1.25rem;
        margin-bottom: 1rem;
        box-shadow: 0 8px 24px rgba(212, 165, 116, 0.3);
    }

    .ai-intro-card h1 {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--sqm-cream, #f5f0e8);
        margin-bottom: 0.5rem;
        letter-spacing: -0.02em;
    }

    .ai-intro-card>p {
        color: var(--sqm-cream-muted, #c8c0b4);
        font-size: 0.95rem;
        margin-bottom: 1.5rem;
        line-height: 1.55;
    }

    .ai-feature-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
    }

    .ai-feature-list li {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        padding: 0.85rem 0.95rem;
        border-radius: 0.75rem;
        background: rgba(245, 240, 232, 0.03);
        border: 1px solid rgba(245, 240, 232, 0.06);
    }

    .ai-feature-list .ai-feature-icon {
        width: 2.1rem;
        height: 2.1rem;
        border-radius: 0.55rem;
        flex-shrink: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: var(--sqm-gold-soft, rgba(212, 165, 116, 0.15));
        color: var(--sqm-gold, #d4a574);
        font-size: 0.9rem;
    }

    .ai-feature-list strong {
        display: block;
        font-size: 0.9rem;
        color: var(--sqm-cream, #f5f0e8);
        margin-bottom: 0.15rem;
    }

    .ai-feature-list span {
        font-size: 0.8rem;
        color: var(--sqm-cream-muted, #c8c0b4);
        line-height: 1.4;
    }

    .ai-chat-card {
        display: flex;
        flex-direction: column;
        min-height: 28rem;
        overflow: hidden;
    }

    .ai-chat-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem 1.25rem;
        border-bottom: 1px solid var(--sqm-border, rgba(245, 240, 232, 0.08));
        background: rgba(37, 37, 40, 0.65);
    }

    .ai-chat-header-avatar {
        width: 2.4rem;
        height: 2.4rem;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, var(--sqm-gold, #d4a574), #b8895a);
        color: var(--sqm-bg, #121214);
    }

    .ai-chat-header h2 {
        font-size: 1rem;
        font-weight: 650;
        margin: 0;
        color: var(--sqm-cream, #f5f0e8);
    }

    .ai-chat-header small {
        color: var(--sqm-cream-muted, #c8c0b4);
        font-size: 0.75rem;
    }

    .ai-status-dot {
        width: 0.5rem;
        height: 0.5rem;
        border-radius: 50%;
        background: #34d399;
        box-shadow: 0 0 0 3px rgba(52, 211, 153, 0.2);
        display: inline-block;
        margin-right: 0.35rem;
    }

    .ai-messages {
        flex: 1;
        max-height: 60vh;
        overflow-y: auto;
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 0.9rem;
        scroll-behavior: smooth;
    }

    .ai-messages::-webkit-scrollbar {
        width: 6px;
    }

    .ai-messages::-webkit-scrollbar-thumb {
        background: rgba(245, 240, 232, 0.15);
        border-radius: 999px;
    }

    .ai-msg {
        display: flex;
        gap: 0.55rem;
        max-width: 88%;
        animation: ai-msg-in 0.28s ease both;
    }

    .ai-msg--user {
        align-self: flex-end;
        flex-direction: row-reverse;
    }

    .ai-msg--bot {
        align-self: flex-start;
    }

    .ai-msg-avatar {
        width: 1.9rem;
        height: 1.9rem;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 0.75rem;
        margin-top: 0.15rem;
    }

    .ai-msg--user .ai-msg-avatar {
        background: linear-gradient(135deg, var(--sqm-gold, #d4a574), #b8895a);
        color: var(--sqm-bg, #121214);
    }

    .ai-msg--bot .ai-msg-avatar {
        background: rgba(245, 240, 232, 0.1);
        color: var(--sqm-gold, #d4a574);
        border: 1px solid rgba(245, 240, 232, 0.12);
    }

    .ai-bubble {
        padding: 0.8rem 1rem;
        border-radius: 1rem;
        font-size: 0.92rem;
        line-height: 1.55;
        white-space: pre-wrap;
        word-break: break-word;
    }

    .ai-msg--user .ai-bubble {
        background: linear-gradient(135deg, var(--sqm-gold, #d4a574) 0%, #b8895a 100%);
        color: var(--sqm-bg, #121214);
        border-bottom-right-radius: 0.3rem;
        box-shadow: 0 8px 20px rgba(212, 165, 116, 0.3);
    }

    .ai-msg--bot .ai-bubble {
        background: rgba(245, 240, 232, 0.08);
        color: var(--sqm-cream, #f5f0e8);
        border: 1px solid rgba(245, 240, 232, 0.1);
        border-bottom-left-radius: 0.3rem;
    }

    .ai-msg--error .ai-bubble {
        background: rgba(229, 115, 115, 0.12);
        border-color: rgba(229, 115, 115, 0.3);
        color: #f0a9a9;
    }

    .ai-typing {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        color: var(--sqm-cream-muted, #c8c0b4);
        font-size: 0.85rem;
    }

    .ai-typing-dots {
        display: inline-flex;
        gap: 0.25rem;
    }

    .ai-typing-dots span {
        width: 0.4rem;
        height: 0.4rem;
        border-radius: 50%;
        background: var(--sqm-gold, #d4a574);
        animation: ai-bounce 1.2s ease-in-out infinite;
    }

    .ai-typing-dots span:nth-child(2) {
        animation-delay: 0.15s;
    }

    .ai-typing-dots span:nth-child(3) {
        animation-delay: 0.3s;
    }

    .ai-composer {
        display: flex;
        gap: 0.65rem;
        padding: 1rem 1.25rem;
        border-top: 1px solid var(--sqm-border, rgba(245, 240, 232, 0.08));
        background: rgba(18, 18, 20, 0.45);
    }

    .ai-composer .form-control {
        background: rgba(245, 240, 232, 0.05);
        border: 1px solid rgba(245, 240, 232, 0.12);
        color: var(--sqm-cream, #f5f0e8);
        border-radius: 999px;
        padding: 0.7rem 1.1rem;
    }

    .ai-composer .form-control::placeholder {
        color: var(--sqm-cream-muted, #c8c0b4);
    }

    .ai-composer .form-control:focus {
        background: rgba(245, 240, 232, 0.07);
        border-color: var(--sqm-gold, #d4a574);
        box-shadow: 0 0 0 0.2rem var(--sqm-gold-soft, rgba(212, 165, 116, 0.15));
        color: var(--sqm-cream, #f5f0e8);
    }

    .ai-send-btn {
        border: none;
        border-radius: 999px;
        padding: 0.7rem 1.25rem;
        font-weight: 600;
        white-space: nowrap;
        background: linear-gradient(135deg, var(--sqm-gold, #d4a574), #b8895a);
        color: var(--sqm-bg, #121214);
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        transition: transform 0.15s ease, opacity 0.15s ease, box-shadow 0.15s ease;
        box-shadow: 0 6px 18px rgba(212, 165, 116, 0.3);
    }

    .ai-send-btn:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 8px 22px rgba(212, 165, 116, 0.4);
        color: var(--sqm-bg, #121214);
    }

    .ai-send-btn:disabled {
        opacity: 0.55;
        cursor: not-allowed;
    }

    @@keyframes ai-msg-in {
        from {
            opacity: 0;
            transform: translateY(8px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes ai-bounce {

        0%,
        80%,
        100% {
            transform: translateY(0);
            opacity: 0.45;
        }

        40% {
            transform: translateY(-4px);
            opacity: 1;
        }
    }

    @@media (max-width: 767.98px) {
        .ai-intro-card {
            margin-bottom: 0.25rem;
        }

        .ai-chat-card {
            min-height: 24rem;
        }
    }
</style>

<section class="ai-page">
    <div class="container">
        <div class="row g-4 align-items-stretch">
            <div class="col-12 col-md-4">
                <aside class="ai-intro-card">
                    <div class="ai-intro-icon" aria-hidden="true">
                        <i class="fa-solid fa-wand-magic-sparkles"></i>
                    </div>
                    <h1>AI Restoran Asistanı</h1>
                    <p>
                        Menü hakkında soru sorun; alerjen, öneri ve fiyat konularında anında yardımcı olsun.
                    </p>
                    <ul class="ai-feature-list">
                        <li>
                            <span class="ai-feature-icon"><i class="fa-solid fa-utensils"></i></span>
                            <div>
                                <strong>Menü önerileri</strong>
                                <span>Damak tadınıza ve bütçenize uygun yemekler bulun.</span>
                            </div>
                        </li>
                        <li>
                            <span class="ai-feature-icon"><i class="fa-solid fa-leaf"></i></span>
                            <div>
                                <strong>Vegan &amp; alerjen</strong>
                                <span>Gluten, fındık ve diyet tercihlerinize göre filtreleyin.</span>
                            </div>
                        </li>
                        <li>
                            <span class="ai-feature-icon"><i class="fa-solid fa-tags"></i></span>
                            <div>
                                <strong>Fiyat bilgisi</strong>
                                <span>Ürün fiyatlarını ve uygun alternatifleri öğrenin.</span>
                            </div>
                        </li>
                        <li>
                            <span class="ai-feature-icon"><i class="fa-solid fa-comments"></i></span>
                            <div>
                                <strong>Doğal sohbet</strong>
                                <span>Günlük dille sorun; asistan menü bağlamıyla yanıtlar.</span>
                            </div>
                        </li>
                    </ul>
                </aside>
            </div>

            <div class="col-12 col-md-8">
                <div class="ai-chat-card">
                    <div class="ai-chat-header">
                        <div class="ai-chat-header-avatar" aria-hidden="true">
                            <i class="fa-solid fa-robot"></i>
                        </div>
                        <div class="flex-grow-1">
                            <h2>Smart QR Menu Asistanı</h2>
                            <small><span class="ai-status-dot"></span>Ollama · llama3 hazır</small>
                        </div>
                    </div>

                    <div id="aiMessages" class="ai-messages" role="log" aria-live="polite">
                        <div class="ai-msg ai-msg--bot">
                            <div class="ai-msg-avatar"><i class="fa-solid fa-robot"></i></div>
                            <div class="ai-bubble">Merhaba! Menüdeki yemekler, alerjenler veya öneriler hakkında
                                sorabilirsiniz.</div>
                            </div>
                        </div>

                        <form id="aiChatForm" class="ai-composer" autocomplete="off">
                            <input type="text" id="aiMessageInput" class="form-control" name="message"
                                   placeholder="Örn: Vegan bir ana yemek önerir misin?" maxlength="2000" required />
                            <button type="submit" id="aiSendBtn" class="ai-send-btn">
                                <i class="fa-solid fa-paper-plane"></i>
                                <span>Gönder</span>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @section Scripts {
        <script>
            (function () {
                var form = document.getElementById('aiChatForm');
                var input = document.getElementById('aiMessageInput');
                var sendBtn = document.getElementById('aiSendBtn');
                var messages = document.getElementById('aiMessages');
                var sendUrl = '@Url.Action("SendMessage", "Ai")';

                function escapeHtml(text) {
                    var div = document.createElement('div');
                    div.textContent = text;
                    return div.innerHTML;
                }

                function scrollToBottom() {
                    messages.scrollTop = messages.scrollHeight;
                }

                function appendMessage(role, text, isError) {
                    var row = document.createElement('div');
                    row.className = 'ai-msg ai-msg--' + role + (isError ? ' ai-msg--error' : '');

                    var avatar = document.createElement('div');
                    avatar.className = 'ai-msg-avatar';
                    avatar.innerHTML = role === 'user'
                        ? '<i class="fa-solid fa-user"></i>'
                        : '<i class="fa-solid fa-robot"></i>';

                    var bubble = document.createElement('div');
                    bubble.className = 'ai-bubble';
                    bubble.innerHTML = escapeHtml(text);

                    row.appendChild(avatar);
                    row.appendChild(bubble);
                    messages.appendChild(row);
                    scrollToBottom();
                    return row;
                }

                function showTyping() {
                    var row = document.createElement('div');
                    row.className = 'ai-msg ai-msg--bot';
                    row.id = 'aiTypingRow';
                    row.innerHTML =
                        '<div class="ai-msg-avatar"><i class="fa-solid fa-robot"></i></div>' +
                        '<div class="ai-bubble">' +
                        '<div class="ai-typing">' +
                        '<span class="ai-typing-dots"><span></span><span></span><span></span></span>' +
                        'Yapay zeka yanıt yazıyor...' +
                        '</div>' +
                        '</div>';
                    messages.appendChild(row);
                    scrollToBottom();
                }

                function hideTyping() {
                    var typing = document.getElementById('aiTypingRow');
                    if (typing) typing.remove();
                }

                function setBusy(busy) {
                    sendBtn.disabled = busy;
                    input.disabled = busy;
                }

                async function sendMessage() {
                    var text = (input.value || '').trim();
                    if (!text) return;

                    appendMessage('user', text);
                    input.value = '';
                    setBusy(true);
                    showTyping();

                    try {
                        var body = new URLSearchParams();
                        body.append('message', text);

                        var response = await fetch(sendUrl, {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8'
                            },
                            body: body.toString()
                        });

                        hideTyping();

                        if (!response.ok) {
                            appendMessage('bot', 'Sunucu hatası oluştu. Lütfen tekrar deneyin.', true);
                            return;
                        }

                        var data = await response.json();
                        if (data && data.success) {
                            appendMessage('bot', data.response || 'Yanıt alınamadı.');
                        } else {
                            appendMessage('bot', (data && data.message) || 'Bir hata oluştu.', true);
                        }
                    } catch (err) {
                        hideTyping();
                        appendMessage('bot', 'Bağlantı hatası. Ollama servisinin çalıştığından emin olun.', true);
                    } finally {
                        setBusy(false);
                        input.focus();
                        scrollToBottom();
                    }
                }

                form.addEventListener('submit', function (e) {
                    e.preventDefault();
                    sendMessage();
                });

                input.addEventListener('keydown', function (e) {
                    if (e.key === 'Enter' && !e.shiftKey) {
                        e.preventDefault();
                        if (!sendBtn.disabled) sendMessage();
                    }
                });
            })();
        </script>
    }
