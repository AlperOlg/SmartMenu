@model Project.Web.Models.AiPageViewModel
@{
    ViewData["Title"] = "AI Asistan";
}

<style>
    .ai-page {
        padding: 2rem 0 3rem;
        background:
            radial-gradient(ellipse 70% 50% at 10% 0%, var(--sqm-gold-soft, rgba(212, 165, 116, 0.14)), transparent 55%),
            radial-gradient(ellipse 50% 40% at 90% 20%, rgba(212, 165, 116, 0.08), transparent 50%);
    }

    .ai-sidebar-card,
    .ai-chat-card {
        background: rgba(28, 28, 31, 0.95);
        border: 1px solid var(--sqm-border, rgba(245, 240, 232, 0.08));
        border-radius: 1rem;
        box-shadow: var(--sqm-shadow, 0 12px 40px rgba(0, 0, 0, 0.5));
        height: 100%;
    }

    /* ---------- Sidebar ---------- */
    .ai-sidebar-card {
        display: flex;
        flex-direction: column;
        padding: 1rem;
        min-height: 28rem;
        max-height: 78vh;
    }

    .ai-sidebar-head {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        margin-bottom: 0.85rem;
    }

    .ai-new-session-btn {
        flex: 1;
        border: none;
        border-radius: 0.75rem;
        padding: 0.7rem 1rem;
        font-weight: 600;
        font-size: 0.9rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        cursor: pointer;
        background: linear-gradient(135deg, var(--sqm-gold, #d4a574), #b8895a);
        color: var(--sqm-bg, #121214);
        transition: transform 0.15s ease, box-shadow 0.15s ease, opacity 0.15s ease;
        box-shadow: 0 6px 18px rgba(212, 165, 116, 0.25);
    }

    .ai-new-session-btn:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 8px 22px rgba(212, 165, 116, 0.4);
    }

    .ai-new-session-btn:disabled,
    .ai-new-session-btn.is-disabled {
        opacity: 0.45;
        cursor: not-allowed;
        box-shadow: none;
    }

    .ai-session-counter {
        font-size: 0.75rem;
        color: var(--sqm-cream-muted, #c8c0b4);
        background: rgba(245, 240, 232, 0.05);
        border: 1px solid rgba(245, 240, 232, 0.08);
        border-radius: 999px;
        padding: 0.25rem 0.55rem;
        white-space: nowrap;
    }

    .ai-sidebar-hint {
        font-size: 0.75rem;
        color: #f0c9a0;
        background: rgba(212, 165, 116, 0.1);
        border: 1px solid rgba(212, 165, 116, 0.25);
        border-radius: 0.6rem;
        padding: 0.55rem 0.7rem;
        margin-bottom: 0.75rem;
        display: flex;
        gap: 0.45rem;
        line-height: 1.4;
    }

    .ai-session-list {
        list-style: none;
        margin: 0;
        padding: 0;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }

    .ai-session-list::-webkit-scrollbar {
        width: 6px;
    }

    .ai-session-list::-webkit-scrollbar-thumb {
        background: rgba(245, 240, 232, 0.15);
        border-radius: 999px;
    }

    .ai-session-empty {
        color: var(--sqm-cream-muted, #c8c0b4);
        font-size: 0.85rem;
        padding: 0.75rem 0.5rem;
        text-align: center;
    }

    .ai-session-item {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        padding: 0.65rem 0.7rem;
        border-radius: 0.7rem;
        cursor: pointer;
        border: 1px solid transparent;
        background: rgba(245, 240, 232, 0.03);
        transition: background 0.15s ease, border-color 0.15s ease;
    }

    .ai-session-item:hover {
        background: rgba(245, 240, 232, 0.07);
    }

    .ai-session-item.active {
        background: var(--sqm-gold-soft, rgba(212, 165, 116, 0.15));
        border-color: rgba(212, 165, 116, 0.4);
    }

    .ai-session-icon {
        color: var(--sqm-gold, #d4a574);
        font-size: 0.85rem;
        flex-shrink: 0;
    }

    .ai-session-title {
        flex: 1;
        color: var(--sqm-cream, #f5f0e8);
        font-size: 0.88rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .ai-session-delete {
        border: none;
        background: transparent;
        color: var(--sqm-cream-muted, #c8c0b4);
        cursor: pointer;
        padding: 0.25rem;
        border-radius: 0.4rem;
        flex-shrink: 0;
        opacity: 0.6;
        transition: color 0.15s ease, opacity 0.15s ease, background 0.15s ease;
    }

    .ai-session-item:hover .ai-session-delete {
        opacity: 1;
    }

    .ai-session-delete:hover {
        color: #f0a9a9;
        background: rgba(229, 115, 115, 0.12);
    }

    /* ---------- Chat ---------- */
    .ai-chat-card {
        display: flex;
        flex-direction: column;
        min-height: 28rem;
        overflow: hidden;
    }

    .ai-chat-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem 1.25rem;
        border-bottom: 1px solid var(--sqm-border, rgba(245, 240, 232, 0.08));
        background: rgba(37, 37, 40, 0.65);
    }

    .ai-chat-header-avatar {
        width: 2.4rem;
        height: 2.4rem;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, var(--sqm-gold, #d4a574), #b8895a);
        color: var(--sqm-bg, #121214);
    }

    .ai-chat-header h2 {
        font-size: 1rem;
        font-weight: 650;
        margin: 0;
        color: var(--sqm-cream, #f5f0e8);
    }

    .ai-chat-header small {
        color: var(--sqm-cream-muted, #c8c0b4);
        font-size: 0.75rem;
    }

    .ai-status-dot {
        width: 0.5rem;
        height: 0.5rem;
        border-radius: 50%;
        background: #34d399;
        box-shadow: 0 0 0 3px rgba(52, 211, 153, 0.2);
        display: inline-block;
        margin-right: 0.35rem;
    }

    .ai-messages {
        flex: 1;
        max-height: 60vh;
        overflow-y: auto;
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 0.9rem;
        scroll-behavior: smooth;
    }

    .ai-messages::-webkit-scrollbar {
        width: 6px;
    }

    .ai-messages::-webkit-scrollbar-thumb {
        background: rgba(245, 240, 232, 0.15);
        border-radius: 999px;
    }

    .ai-msg {
        display: flex;
        gap: 0.55rem;
        max-width: 88%;
        animation: ai-msg-in 0.28s ease both;
    }

    .ai-msg--user {
        align-self: flex-end;
        flex-direction: row-reverse;
    }

    .ai-msg--bot {
        align-self: flex-start;
    }

    .ai-msg-avatar {
        width: 1.9rem;
        height: 1.9rem;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 0.75rem;
        margin-top: 0.15rem;
    }

    .ai-msg--user .ai-msg-avatar {
        background: linear-gradient(135deg, var(--sqm-gold, #d4a574), #b8895a);
        color: var(--sqm-bg, #121214);
    }

    .ai-msg--bot .ai-msg-avatar {
        background: rgba(245, 240, 232, 0.1);
        color: var(--sqm-gold, #d4a574);
        border: 1px solid rgba(245, 240, 232, 0.12);
    }

    .ai-bubble {
        padding: 0.8rem 1rem;
        border-radius: 1rem;
        font-size: 0.92rem;
        line-height: 1.55;
        white-space: pre-wrap;
        word-break: break-word;
    }

    .ai-msg--user .ai-bubble {
        background: linear-gradient(135deg, var(--sqm-gold, #d4a574) 0%, #b8895a 100%);
        color: var(--sqm-bg, #121214);
        border-bottom-right-radius: 0.3rem;
        box-shadow: 0 8px 20px rgba(212, 165, 116, 0.3);
    }

    .ai-msg--bot .ai-bubble {
        background: rgba(245, 240, 232, 0.08);
        color: var(--sqm-cream, #f5f0e8);
        border: 1px solid rgba(245, 240, 232, 0.1);
        border-bottom-left-radius: 0.3rem;
    }

    .ai-msg--error .ai-bubble {
        background: rgba(229, 115, 115, 0.12);
        border-color: rgba(229, 115, 115, 0.3);
        color: #f0a9a9;
    }

    .ai-typing {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        color: var(--sqm-cream-muted, #c8c0b4);
        font-size: 0.85rem;
    }

    .ai-typing-dots {
        display: inline-flex;
        gap: 0.25rem;
    }

    .ai-typing-dots span {
        width: 0.4rem;
        height: 0.4rem;
        border-radius: 50%;
        background: var(--sqm-gold, #d4a574);
        animation: ai-bounce 1.2s ease-in-out infinite;
    }

    .ai-typing-dots span:nth-child(2) {
        animation-delay: 0.15s;
    }

    .ai-typing-dots span:nth-child(3) {
        animation-delay: 0.3s;
    }

    .ai-composer {
        display: flex;
        gap: 0.65rem;
        padding: 1rem 1.25rem;
        border-top: 1px solid var(--sqm-border, rgba(245, 240, 232, 0.08));
        background: rgba(18, 18, 20, 0.45);
    }

    .ai-composer .form-control {
        background: rgba(245, 240, 232, 0.05);
        border: 1px solid rgba(245, 240, 232, 0.12);
        color: var(--sqm-cream, #f5f0e8);
        border-radius: 999px;
        padding: 0.7rem 1.1rem;
    }

    .ai-composer .form-control::placeholder {
        color: var(--sqm-cream-muted, #c8c0b4);
    }

    .ai-composer .form-control:focus {
        background: rgba(245, 240, 232, 0.07);
        border-color: var(--sqm-gold, #d4a574);
        box-shadow: 0 0 0 0.2rem var(--sqm-gold-soft, rgba(212, 165, 116, 0.15));
        color: var(--sqm-cream, #f5f0e8);
    }

    .ai-send-btn {
        border: none;
        border-radius: 999px;
        padding: 0.7rem 1.25rem;
        font-weight: 600;
        white-space: nowrap;
        background: linear-gradient(135deg, var(--sqm-gold, #d4a574), #b8895a);
        color: var(--sqm-bg, #121214);
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        transition: transform 0.15s ease, opacity 0.15s ease, box-shadow 0.15s ease;
        box-shadow: 0 6px 18px rgba(212, 165, 116, 0.3);
    }

    .ai-send-btn:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 8px 22px rgba(212, 165, 116, 0.4);
        color: var(--sqm-bg, #121214);
    }

    .ai-send-btn:disabled {
        opacity: 0.55;
        cursor: not-allowed;
    }

    @@keyframes ai-msg-in {
        from {
            opacity: 0;
            transform: translateY(8px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes ai-bounce {

        0%,
        80%,
        100% {
            transform: translateY(0);
            opacity: 0.45;
        }

        40% {
            transform: translateY(-4px);
            opacity: 1;
        }
    }

    @@media (max-width: 767.98px) {
        .ai-sidebar-card {
            margin-bottom: 0.25rem;
            max-height: 20rem;
        }

        .ai-chat-card {
            min-height: 24rem;
        }
    }
</style>

@Html.AntiForgeryToken()

<section class="ai-page">
    <div class="container">
        <div class="row g-4 align-items-stretch">
            <div class="col-12 col-md-3">
                <aside class="ai-sidebar-card" id="aiSidebar">
                    @await Html.PartialAsync("_ChatSidebarPartial", Model.Sessions)
                </aside>
            </div>

            <div class="col-12 col-md-9">
                <div class="ai-chat-card">
                    <div class="ai-chat-header">
                        <div class="ai-chat-header-avatar" aria-hidden="true">
                            <i class="fa-solid fa-robot"></i>
                        </div>
                        <div class="flex-grow-1">
                            <h2>Smart QR Menu Asistanı</h2>
                            <small><span class="ai-status-dot"></span>Sohbet geçmişi aktif</small>
                        </div>
                    </div>

                    <div id="aiMessages" class="ai-messages" role="log" aria-live="polite">
                        @if (Model.Messages.Count == 0)
                        {
                            <div class="ai-msg ai-msg--bot">
                                <div class="ai-msg-avatar"><i class="fa-solid fa-robot"></i></div>
                                <div class="ai-bubble">Merhaba! Menüdeki yemekler, alerjenler veya öneriler hakkında
                                    sorabilirsiniz.</div>
                            </div>
                        }
                        else
                        {
                            @foreach (var msg in Model.Messages)
                            {
                                <div class="ai-msg @(msg.IsUser ? "ai-msg--user" : "ai-msg--bot")">
                                    <div class="ai-msg-avatar">
                                        <i class="fa-solid @(msg.IsUser ? "fa-user" : "fa-robot")"></i>
                                    </div>
                                    <div class="ai-bubble">@msg.Content</div>
                                </div>
                            }
                        }
                    </div>

                    <form id="aiChatForm" class="ai-composer" autocomplete="off">
                        <input type="text" id="aiMessageInput" class="form-control" name="message"
                               placeholder="Örn: Vegan bir ana yemek önerir misin?" maxlength="2000" required />
                        <button type="submit" id="aiSendBtn" class="ai-send-btn">
                            <i class="fa-solid fa-paper-plane"></i>
                            <span>Gönder</span>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        window.AiChat = (function () {
            var messages = document.getElementById('aiMessages');
            var sidebar = document.getElementById('aiSidebar');
            var form = document.getElementById('aiChatForm');
            var input = document.getElementById('aiMessageInput');
            var sendBtn = document.getElementById('aiSendBtn');

            var currentSessionId = @Model.CurrentSessionId;

            var urls = {
                create: '@Url.Action("CreateNewSession", "Ai")',
                select: '@Url.Action("SelectSession", "Ai")',
                delete: '@Url.Action("DeleteSession", "Ai")',
                send: '@Url.Action("SendMessage", "Ai")'
            };

            function token() {
                var el = document.querySelector('input[name="__RequestVerificationToken"]');
                return el ? el.value : '';
            }

            async function postForm(url, data) {
                var body = new URLSearchParams();
                body.append('__RequestVerificationToken', token());
                Object.keys(data || {}).forEach(function (k) { body.append(k, data[k]); });

                var res = await fetch(url, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8',
                        'RequestVerificationToken': token()
                    },
                    body: body.toString()
                });
                if (!res.ok) throw new Error('http ' + res.status);
                return await res.json();
            }

            function escapeHtml(text) {
                var div = document.createElement('div');
                div.textContent = text;
                return div.innerHTML;
            }

            function scrollToBottom() {
                messages.scrollTop = messages.scrollHeight;
            }

            function clearMessages() {
                messages.innerHTML = '';
            }

            function welcome() {
                clearMessages();
                appendMessage('bot', 'Merhaba! Menüdeki yemekler, alerjenler veya öneriler hakkında sorabilirsiniz.');
            }

            function appendMessage(role, text, isError) {
                var uiRole = role === 'user' ? 'user' : 'bot';
                var row = document.createElement('div');
                row.className = 'ai-msg ai-msg--' + uiRole + (isError ? ' ai-msg--error' : '');

                var avatar = document.createElement('div');
                avatar.className = 'ai-msg-avatar';
                avatar.innerHTML = uiRole === 'user'
                    ? '<i class="fa-solid fa-user"></i>'
                    : '<i class="fa-solid fa-robot"></i>';

                var bubble = document.createElement('div');
                bubble.className = 'ai-bubble';
                bubble.innerHTML = escapeHtml(text);

                row.appendChild(avatar);
                row.appendChild(bubble);
                messages.appendChild(row);
                scrollToBottom();
                return row;
            }

            function showTyping() {
                var row = document.createElement('div');
                row.className = 'ai-msg ai-msg--bot';
                row.id = 'aiTypingRow';
                row.innerHTML =
                    '<div class="ai-msg-avatar"><i class="fa-solid fa-robot"></i></div>' +
                    '<div class="ai-bubble"><div class="ai-typing">' +
                    '<span class="ai-typing-dots"><span></span><span></span><span></span></span>' +
                    'Yapay zeka yanıt yazıyor...</div></div>';
                messages.appendChild(row);
                scrollToBottom();
            }

            function hideTyping() {
                var t = document.getElementById('aiTypingRow');
                if (t) t.remove();
            }

            function setBusy(busy) {
                sendBtn.disabled = busy;
                input.disabled = busy;
            }

            function markActive(id) {
                var items = sidebar.querySelectorAll('.ai-session-item');
                items.forEach(function (el) {
                    var sid = parseInt(el.getAttribute('data-session-id'), 10);
                    el.classList.toggle('active', sid === id);
                });
            }

            function renderHistory(list) {
                clearMessages();
                if (!list || list.length === 0) {
                    welcome();
                    return;
                }
                list.forEach(function (m) { appendMessage(m.role, m.content); });
            }

            function playSound(name) {
                if (window.SoundManager && typeof window.SoundManager.play === 'function') {
                    window.SoundManager.play(name);
                }
            }

            async function createSession() {
                try {
                    var data = await postForm(urls.create, {});
                    if (!data.success) {
                        playSound('error');
                        alert(data.message || 'Yeni sohbet oluşturulamadı.');
                        return;
                    }
                    playSound('success');
                    sidebar.innerHTML = data.sidebarHtml;
                    currentSessionId = data.sessionId;
                    markActive(currentSessionId);
                    welcome();
                    input.focus();
                } catch (e) {
                    playSound('error');
                    alert('Yeni sohbet oluşturulurken bir hata oluştu.');
                }
            }

            async function selectSession(id) {
                if (id === currentSessionId) return;
                try {
                    var data = await postForm(urls.select, { sessionId: id });
                    if (!data.success) {
                        playSound('error');
                        alert(data.message || 'Sohbet yüklenemedi.');
                        return;
                    }
                    currentSessionId = data.sessionId;
                    markActive(currentSessionId);
                    renderHistory(data.messages);
                } catch (e) {
                    playSound('error');
                    alert('Sohbet yüklenirken bir hata oluştu.');
                }
            }

            async function deleteSession(id) {
                if (!confirm('Bu sohbeti silmek istediğinize emin misiniz?')) return;
                try {
                    var data = await postForm(urls.delete, { sessionId: id });
                    if (!data.success) {
                        playSound('error');
                        alert(data.message || 'Sohbet silinemedi.');
                        return;
                    }
                    playSound('success2');
                    sidebar.innerHTML = data.sidebarHtml;

                    // Silinen sohbet açıksa, yeni geçerli sohbete geç.
                    if (id === currentSessionId) {
                        currentSessionId = data.currentSessionId;
                        markActive(currentSessionId);
                        // Yeni geçerli sohbetin geçmişini yükle.
                        var sel = await postForm(urls.select, { sessionId: currentSessionId });
                        if (sel.success) {
                            renderHistory(sel.messages);
                        } else {
                            welcome();
                        }
                    } else {
                        markActive(currentSessionId);
                    }
                } catch (e) {
                    playSound('error');
                    alert('Sohbet silinirken bir hata oluştu.');
                }
            }

            function updateSidebarTitle(id, title) {
                if (!title) return;
                var item = sidebar.querySelector('.ai-session-item[data-session-id="' + id + '"] .ai-session-title');
                if (item) {
                    item.textContent = title;
                    item.setAttribute('title', title);
                }
            }

            async function sendMessage() {
                var text = (input.value || '').trim();
                if (!text) return;

                appendMessage('user', text);
                playSound('aiMessage');
                input.value = '';
                setBusy(true);
                showTyping();

                try {
                    var data = await postForm(urls.send, { sessionId: currentSessionId, message: text });
                    hideTyping();

                    if (data && data.success) {
                        appendMessage('bot', data.response || 'Yanıt alınamadı.');
                        playSound('aiMessage');
                        updateSidebarTitle(currentSessionId, data.title);
                    } else {
                        appendMessage('bot', (data && data.message) || 'Bir hata oluştu.', true);
                        playSound('error');
                    }
                } catch (e) {
                    hideTyping();
                    appendMessage('bot', 'Bağlantı hatası. Lütfen tekrar deneyin.', true);
                    playSound('error');
                } finally {
                    setBusy(false);
                    input.focus();
                    scrollToBottom();
                }
            }

            form.addEventListener('submit', function (e) {
                e.preventDefault();
                sendMessage();
            });

            input.addEventListener('keydown', function (e) {
                if (e.key === 'Enter' && !e.shiftKey) {
                    e.preventDefault();
                    if (!sendBtn.disabled) sendMessage();
                }
            });

            // İlk yüklemede açık sohbeti vurgula.
            markActive(currentSessionId);
            scrollToBottom();

            return {
                createSession: createSession,
                selectSession: selectSession,
                deleteSession: deleteSession
            };
        })();
    </script>
}
